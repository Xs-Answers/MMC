        <mxCell id="formula_title" value="&lt;b&gt;综合评价得分计算机制 (Ensemble Scoring)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#2B579A;" vertex="1" parent="1">
          <mxGeometry x="50" y="450" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="formula_text" value="$$S_j = \sum_{k=1}^{5} w_k \cdot \text{Score}_{k,j}$$&lt;br&gt;&lt;font size=&quot;1&quot; color=&quot;#555555&quot;&gt;其中 $w_k$ 为各维度权重，$\text{Score}_{k,j}$ 为第 $j$ 个指标在第 $k$ 种算法下归一化后的得分。&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="45" y="480" width="370" height="60" as="geometry" />
        </mxCell>

