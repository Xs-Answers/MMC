00000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="590" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_2_1" value="中危界定 (5-9%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffebb3;fontColor=#996b00;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="260" y="590" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_2_2" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="430" y="590" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_2_3" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="600" y="590" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r1_2" value="已确诊高血脂&#10;或某项靶向指标&#10;发生显著异常" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;fillColor=#fcfcfc;" vertex="1" parent="1"><mxGeometry x="40" y="630" width="100" height="120" as="geometry" /></mxCell><mxCell id="m_r2_3" value="活动能力良好&#10;(分数≥60)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="630" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_3_1" value="中危界定 (5-9%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffebb3;fontColor=#996b00;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="260" y="630" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_3_2" value="中危界定 (5-9%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffebb3;fontColor=#996b00;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="430" y="630" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_3_3" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="600" y="630" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r2_4" value="轻度活动受限&#10;(40≤分数&lt;60)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="670" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_4_1" value="中危界定 (5-9%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffebb3;fontColor=#996b00;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="260" y="670" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_4_2" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="430" y="670" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_4_3" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="600" y="670" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r2_5" value="显著活动受限&#10;(分数&lt;40)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="710" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_5_1" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="260" y="710" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_5_2" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="430" y="710" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_5_3" value="高危突变 (≥10%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffd1cf;fontColor=#9e1511;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="600" y="710" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_footer" value="&lt;b&gt;【 理论融合说明 】&lt;/b&gt;&lt;br&gt;• &lt;b&gt;血脂异常识别阻断&lt;/b&gt;：遵循赛题核心指标与预警诊断要求，任意单项生化边界极端异常，无条件降级入下半层警戒组。&lt;br&gt;• &lt;b&gt;特征耦合非线性预设&lt;/b&gt;：矩阵划界高度契合前述随机森林(Random Forest)的 Gini 权重排序及互信息(MI)非线性评估结论。&lt;br&gt;&nbsp;&nbsp;例如：“重期痰湿伴严重活动障碍”即使处于血脂正常组，仍表现出高位(红色)共线性致病倾向，实现无缝隐匿预警。&lt;br&gt;• &lt;b&gt;与运筹模型耦合机制&lt;/b&gt;：红黄绿危阶直通下文最优化干预模型，作为划定干预强度、限制月度成本(≤2000元)的核心参量。" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#cccccc;fillColor=#fcfcfc;fontColor=#444444;fontStyle=0;fontSize=12;align=left;spacingLeft=10;spacingTop=6;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="40" y="780" width="720" height="110" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>