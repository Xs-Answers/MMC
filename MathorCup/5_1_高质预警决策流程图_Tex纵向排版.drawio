<mxfile host="Electron" modified="2023-10-25T00:00:00.000Z" agent="Mozilla/5.0" version="21.5.0" type="device"><diagram id="diagram1" name="Page-1"><mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="中年人群高血脂症与痰湿体质综合风险评估流程图" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;fontSize=19;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1"><mxGeometry x="100" y="20" width="600" height="40" as="geometry" /></mxCell><mxCell id="n_start" value="初筛：中老年评估及干预体检总人群" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#f5f5f5;fontColor=#000000;fontStyle=1;fontSize=13;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="280" y="80" width="240" height="40" as="geometry" /></mxCell><mxCell id="d1" value="是否存在较严重的合并病史？&#10;(如严重冠心病、缺血性脑卒中等)" style="rhombus;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#eef5ff;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="260" y="150" width="280" height="70" as="geometry" /></mxCell><mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;fontColor=#333333;strokeColor=#333333;" edge="1" parent="1" source="n_start" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lbl_yes" value="是" style="text;html=1;align=center;fontColor=#c00000;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="160" y="160" width="40" height="20" as="geometry" /></mxCell><mxCell id="n_left" value="&lt;b&gt;【极高危干预分流】&lt;/b&gt;&lt;br&gt;&lt;br&gt;符合下列任意条件者直接纳入极危预警：&lt;br&gt;&lt;br&gt;① 近期心肌梗死或重大脑血管病史&lt;br&gt;② 极度高胆固醇 (LDL-C ≥4.9 mmol/L)&lt;br&gt;③ 满级重度痰湿伴日常活动完全受限&lt;br&gt;④ 不可逆的器官靶向病变" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#fff0f0;fontColor=#000000;fontStyle=0;fontSize=11;align=left;spacingLeft=10;spacingTop=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="40" y="260" width="280" height="150" as="geometry" /></mxCell><mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;fontColor=#333333;strokeColor=#333333;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1" target="n_left"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lbl_no" value="否" style="text;html=1;align=center;fontColor=#2ca02c;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="600" y="160" width="40" height="20" as="geometry" /></mxCell><mxCell id="n_right" value="不符合上方左侧各项危重症指标者，&#10;进入常规队列，综合下列表格确立危险等级" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#f0faef;fontColor=#000000;fontStyle=1;fontSize=12;align=center;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="480" y="260" width="280" height="60" as="geometry" /></mxCell><mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;fontColor=#333333;strokeColor=#333333;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1" target="n_right"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n_mat_title" value="多维特征交叉预警与发病层级评估矩阵" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#e6f0ff;fontColor=#003380;fontStyle=1;fontSize=13;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="40" y="430" width="720" height="30" as="geometry" /></mxCell><mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;fontColor=#333333;strokeColor=#333333;exitX=0.5;exitY=1;entryX=0.79;entryY=0;" edge="1" parent="1" source="n_right" target="n_mat_title"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="m_h1" value="核心血脂状态 | 日常活动受限量级" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#f8f9fa;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;fillColor=#f8f9fa;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="220" height="40" as="geometry" /></mxCell><mxCell id="m_h2" value="无或轻度痰湿&#10;(0≤积分&lt;60)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#f8f9fa;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="260" y="470" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_h3" value="中度痰湿阶段&#10;(60≤积分&lt;80)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#f8f9fa;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="430" y="470" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_h4" value="重度痰湿预警&#10;(≥80分)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#f8f9fa;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="600" y="470" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r1_1" value="未确诊高血脂&#10;且各项生化指标&#10;无异常溢出" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="510" width="100" height="120" as="geometry" /></mxCell><mxCell id="m_r2_0" value="活动能力良好&#10;(分数≥60)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1.2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="510" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_0_1" value="低危人群 (&lt;5%)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#d4edd9;fontColor=#