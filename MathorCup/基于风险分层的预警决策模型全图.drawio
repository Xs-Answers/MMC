<mxfile host="Electron" modified="2023-10-25T00:00:00.000Z" agent="Mozilla/5.0" version="21.5.0" type="device"><diagram id="diagram1" name="Page-1"><mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1000" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="中年人群高血脂症与痰湿及干预综合预警评估流程图" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="300" y="20" width="400" height="30" as="geometry" /></mxCell><mxCell id="n_start" value="初筛中老年评估及干预体检总人群" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="400" y="70" width="200" height="40" as="geometry" /></mxCell><mxCell id="d1" value="是否发生过相关的危急重症？&#10;（极严重的冠病、不可逆的躯体衰败）" style="rhombus;whiteSpace=wrap;html=1;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="380" y="140" width="240" height="60" as="geometry" /></mxCell><mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="n_start" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n_secondary_label" value="是" style="text;html=1;align=center;" vertex="1" parent="1"><mxGeometry x="290" y="140" width="40" height="20" as="geometry" /></mxCell><mxCell id="n_primary_label" value="否" style="text;html=1;align=center;" vertex="1" parent="1"><mxGeometry x="670" y="140" width="40" height="20" as="geometry" /></mxCell><mxCell id="n_secondary" value="二级强化预防流程" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="260" y="210" width="160" height="40" as="geometry" /></mxCell><mxCell id="n_primary" value="综合等级评估与日常干预" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="580" y="210" width="160" height="40" as="geometry" /></mxCell><mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1" target="n_secondary"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1" target="n_primary"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n_sec_box" value="符合下列任意条件者，可直接划为极高危干预人群快速跟进：&#10;&#10;① 已确诊且无法扭转的相关原发代谢失序重症&#10;② 重度痰湿（积分≥95）合并日常全功能活动瘫痪&#10;③ 其他超出基本医疗调整干预容忍限度的病状" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;spacingLeft=10;spacingTop=10;fontStyle=0" vertex="1" parent="1"><mxGeometry x="140" y="310" width="330" height="90" as="geometry" /></mxCell><mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;" edge="1" parent="1" source="n_secondary" target="n_sec_box"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n_prim_box" value="不符合左侧直出条件者，进入下表综合多维度评价以细化至 低/中/高 危险层级" style="shape=rectangle;whiteSpace=wrap;html=1;align=center;fontStyle=0" vertex="1" parent="1"><mxGeometry x="520" y="310" width="280" height="40" as="geometry" /></mxCell><mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;" edge="1" parent="1" source="n_primary" target="n_prim_box"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="p_matrix_anchor" value="" style="text;html=1;" vertex="1" parent="1"><mxGeometry x="660" y="420" width="0" height="0" as="geometry" /></mxCell><mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_prim_box" target="p_matrix_anchor"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="m_wrapper" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="140" y="450" width="720" height="310" as="geometry" /></mxCell><mxCell id="m_h1" value="痰湿体质积水平分层 (分)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="380" y="420" width="480" height="30" as="geometry" /></mxCell><mxCell id="m_h2_1" value="核心血脂状态&#10;分层" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="450" width="100" height="40" as="geometry" /></mxCell><mxCell id="m_h2_2" value="日常活动受限评分&#10;(ADL+IADL总量)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="450" width="140" height="40" as="geometry" /></mxCell><mxCell id="m_h2_3" value="无或轻度痰湿分&#10;(0≤积分&lt;60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="380" y="450" width="160" height="40" as="geometry" /></mxCell><mxCell id="m_h2_4" value="中度痰湿失常&#10;(60≤积分&lt;80)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="540" y="450" width="160" height="40" as="geometry" /></mxCell><mxCell id="m_h2_5" value="重度痰湿特征&#10;(80≤积分≤100)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="700" y="450" width="160" height="40" as="geometry" /></mxCell><mxCell id="m_row1_1" value="未诊断高血脂&#10;且核心各项&#10;指标正常区" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;fillColor=#f9fbf8;" vertex="1" parent="1"><mxGeometry x="140" y="490" width="100" height="120" as="geometry" /></mxCell><mxCell id="m_row2_1" value="已确诊高血脂&#10;或某项核心指标&#10;显著异常" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;fillColor=#fffdf8;" vertex="1" parent="1"><mxGeometry x="140" y="610" width="100" height="120" as="geometry" /></mxCell><mxCell id="act1_0" value="活动能力良好&#10;(活动量≥60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="490" width="140" height="40" as="geometry" /></mxCell><mxCell id="act2_0" value="活动能力良好&#10;(活动量≥60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="610" width="140" height="40" as="geometry" /></mxCell><mxCell id="act1_1" value="轻度活动受限&#10;(40≤活动量&lt;60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="530" width="140" height="40" as="geometry" /></mxCell><mxCell id="act2_1" value="轻度活动受限&#10;(40≤活动量&lt;60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="650" width="140" height="40" as="geometry" /></mxCell><mxCell id="act1_2" value="显著活动受限&#10;(活动量&lt;40)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="570" width="140" height="40" as="geometry" /></mxCell><mxCell id="act2_2" value="显著活动受限&#10;(活动量&lt;40)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="690" width="140" height="40" as="geometry" /></mxCell><mxCell id="c1_0_0" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="380" y="490" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_0_1" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="540" y="490" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_0_2" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="700" y="490" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_1_0" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="380" y="530" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_1_1" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="540" y="530" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_1_2" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="700" y="530" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_2_0" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="380" y="570" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_2_1" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="540" y="570" width="160" height="40" as="geometry" /></mxCell><mxCell id="c1_2_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="700" y="570" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_0_0" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="380" y="610" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_0_1" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="540" y="610" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_0_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="700" y="610" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_1_0" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="380" y="650" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_1_1" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="540" y="650" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_1_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="700" y="650" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_2_0" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="380" y="690" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_2_1" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="540" y="690" width="160" height="40" as="geometry" /></mxCell><mxCell id="c2_2_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="700" y="690" width="160" height="40" as="geometry" /></mxCell><mxCell id="m_anno" value="&lt;b&gt;图注及模型参数判定说明：&lt;/b&gt;&lt;br&gt;1. &lt;b&gt;高血脂初筛与指标截断&lt;/b&gt;：参照《赛题》诊断指南及血指标健康预警阈值。凡满足诊断模型正向激活，或任意核心生化指标（如：TG/TC 等偏态分布尾部超越截断极值）异动者归左层。&lt;br&gt;2. &lt;b&gt;特征边界量化界定与分类矩阵说明 (非线性耦合特征预警)&lt;/b&gt;：此量化分层表格的界段直接映射了决策树 Gini 重要度评估结构 [2] 以及互信息（MI）对非线性关系的放大效应 [4]；具体阈值如：高危级对应于“血脂指标异常且痰湿积分≥80”及隐匿恶化物“血脂无异常但痰湿积分≥60且活动能力评分低于40分”等联合规则，精确对标多指标干预成本模型。&lt;br&gt;3. &lt;b&gt;对调理模型（第三问）的触发机制&lt;/b&gt;：高位（红）及中位（黄）将触发 6 个月跟踪的中期干预流程分配算法，进而进入成本与效用的最优寻梯。" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;fontSize=12;spacing=4;spacingTop=6;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="140" y="780" width="720" height="80" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>