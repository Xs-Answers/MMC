<mxfile host="Electron" modified="2023-10-25T00:00:00.000Z" agent="Mozilla/5.0" version="21.5.0" type="device"><diagram id="diagram1" name="Page-1"><mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="中年人群高血脂症与痰湿体质综合风险评估流程图" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="20" width="600" height="40" as="geometry" /></mxCell><mxCell id="n_start" value="初筛中老年评估及干预体检总人群" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;fontStyle=1;fontSize=13;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="280" y="80" width="240" height="40" as="geometry" /></mxCell><mxCell id="d1" value="是否发生过相关的危急重症？&#10;（极严重的冠病、不可逆的躯体衰败）" style="rhombus;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="150" width="280" height="70" as="geometry" /></mxCell><mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;fontColor=#000000;strokeColor=#000000;" edge="1" parent="1" source="n_start" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lbl_yes" value="是" style="text;html=1;align=center;fontColor=#000000;fontStyle=0;fontSize=13;" vertex="1" parent="1"><mxGeometry x="160" y="160" width="40" height="20" as="geometry" /></mxCell><mxCell id="n_left" value="符合下列任意条件者，可直接划为极高危干预人群快速跟进：&lt;br&gt;&lt;br&gt;① 已确诊且无法扭转的相关原发代谢失序重症&lt;br&gt;② 重度痰湿（积分≥95）合并日常全功能活动瘫痪&lt;br&gt;③ 其他超出基本医疗调整干预容忍限度的病状" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;align=left;spacingLeft=10;spacingTop=6;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="40" y="260" width="280" height="120" as="geometry" /></mxCell><mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;fontColor=#000000;strokeColor=#000000;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1" target="n_left"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lbl_no" value="否" style="text;html=1;align=center;fontColor=#000000;fontStyle=0;fontSize=13;" vertex="1" parent="1"><mxGeometry x="600" y="160" width="40" height="20" as="geometry" /></mxCell><mxCell id="n_right" value="不符合左侧直出条件者，进入下表综合多维度评价以细化至 低/中/高 危险层级" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;fontStyle=1;fontSize=12;align=center;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="480" y="260" width="280" height="60" as="geometry" /></mxCell><mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;fontColor=#000000;strokeColor=#000000;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="d1" target="n_right"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;fontColor=#000000;strokeColor=#000000;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n_right" target="m_h4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="m_h0" value="痰湿体质积水平分层 (分)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;fontSize=13;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="400" width="510" height="30" as="geometry" /></mxCell><mxCell id="m_h1" value="核心血脂状态&#10;分层" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;fillColor=#f2f2f2;" vertex="1" parent="1"><mxGeometry x="40" y="430" width="100" height="40" as="geometry" /></mxCell><mxCell id="m_h_adl" value="日常活动受限评分&#10;(ADL+IADL总量)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;fillColor=#f2f2f2;" vertex="1" parent="1"><mxGeometry x="140" y="430" width="120" height="40" as="geometry" /></mxCell><mxCell id="m_h2" value="无或轻度痰湿&#10;(0≤积分&lt;60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="260" y="430" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_h3" value="中度痰湿阶段&#10;(60≤积分&lt;80)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="430" y="430" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_h4" value="重度痰湿预警&#10;(≥80分)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f2f2f2;fontColor=#000000;fontStyle=1;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="600" y="430" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r1_1" value="未诊断高血脂&#10;且核心各项&#10;指标正常区" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;fillColor=#f9fbf8;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="100" height="120" as="geometry" /></mxCell><mxCell id="m_r2_0" value="活动能力良好&#10;(活动量≥60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="470" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_0_1" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="470" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_0_2" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="430" y="470" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_0_3" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="600" y="470" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r2_1" value="轻度活动受限&#10;(40≤活动量&lt;60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="510" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_1_1" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="510" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_1_2" value="低危 (&lt;5%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#92d050;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="430" y="510" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_1_3" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="600" y="510" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r2_2" value="显著活动受限&#10;(活动量&lt;40)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="550" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_2_1" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="550" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_2_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="430" y="550" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_2_3" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="600" y="550" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r1_2" value="已确诊高血脂&#10;或某项核心指标&#10;显著异常" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;fillColor=#fffdf8;" vertex="1" parent="1"><mxGeometry x="40" y="590" width="100" height="120" as="geometry" /></mxCell><mxCell id="m_r2_3" value="活动能力良好&#10;(活动量≥60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="590" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_3_1" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="590" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_3_2" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="430" y="590" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_3_3" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="600" y="590" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r2_4" value="轻度活动受限&#10;(40≤活动量&lt;60)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="630" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_4_1" value="中度/中危 (5%~9%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffc000;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="630" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_4_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="430" y="630" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_4_3" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="600" y="630" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_r2_5" value="显著活动受限&#10;(活动量&lt;40)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#ffffff;fontColor=#000000;fontStyle=0;fontSize=11;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="670" width="120" height="40" as="geometry" /></mxCell><mxCell id="c_5_1" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="260" y="670" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_5_2" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="430" y="670" width="170" height="40" as="geometry" /></mxCell><mxCell id="c_5_3" value="高度预警 (≥10%)" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#c00000;fontColor=#ffffff;fontStyle=0;fontSize=11;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="600" y="670" width="170" height="40" as="geometry" /></mxCell><mxCell id="m_footer" value="&lt;b&gt;图注及模型参数判定说明：&lt;/b&gt;&lt;br&gt;1. &lt;b&gt;高血脂初筛与指标截断&lt;/b&gt;：参照《赛题》诊断指南及血指标健康预警阈值。凡满足诊断模型正向激活，或任意核心生化指标（如：TG/TC 等偏态分布尾部超越截断极值）异动者归左层。&lt;br&gt;2. &lt;b&gt;特征边界量化界定与分类矩阵说明 (非线性耦合特征预警)&lt;/b&gt;：此量化分层表格的界段直接映射了决策树 Gini 重要度评估结构 [2] 以及互信息（MI）对非线性关系的放大效应 [4]；&lt;br&gt;&nbsp;&nbsp;具体阈值如：高危级对应于“血脂指标异常且痰湿积分≥80”及隐匿恶化物“血脂无异常但痰湿积分≥60且活动能力评分低于40分”等联合规则，精确对标多指标干预成本模型。&lt;br&gt;3. &lt;b&gt;对调理模型（第三问）的触发机制&lt;/b&gt;：高位（红）及中位（黄）将触发 6 个月跟踪的中期干预流程分配算法，进而进入成本与效用的最优寻梯。" style="text;html=1;strokeColor=none;fillColor=none;fontColor=#000000;fontStyle=0;fontSize=12;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="40" y="740" width="720" height="110" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>